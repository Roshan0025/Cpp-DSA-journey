#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter a number to see its multiplication table: ";
    cin >> n;

    // Standard for loop: initialization, condition, and increment
    for (int i = 1; i <= 10; i++) {
        cout << n << " x " << i << " = " << n * i << endl;
    }

    return 0;
}
