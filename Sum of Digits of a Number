#include <iostream>
using namespace std;

int main() {
    int num, sum = 0, digit;
    cout << "Enter a number: ";
    cin >> num;

    // Use while loop because we don't know the exact number of iterations
    while (num != 0) {
        digit = num % 10;    // Get the last digit
        sum += digit;        // Add it to the total sum
        num /= 10;           // Remove the last digit from the number
    }

    cout << "Sum of digits: " << sum << endl;
    return 0;
}
