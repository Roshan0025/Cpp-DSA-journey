#include <iostream>

int main() {
    int totalRows;
    std::cout << "Enter number of rows to print: ";
    std::cin >> totalRows;

    // Outer loop handles the vertical grid layout (rows)
    for (int row = 1; row <= totalRows; ++row) {
        
        // Inner loop handles the horizontal item count per row
        for (int col = 1; col <= row; ++col) {
            std::cout << "* ";
        }
        
        // Moves the cursor to the next line after completing a row
        std::cout << "\n";
    }

    return 0;
}
